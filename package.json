{
  "name": "zadaci",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:clear": "pnpm dlx tsx ./server/database/clear.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-types": "tsc --noEmit",
    "check": "pnpm run check-types && pnpm run lint",
    "fix-tailwind-quotes": "python3 scripts/fix-tailwind-quotes.py",
    "fix-and-check": "pnpm run check-types && pnpm run lint:fix && pnpm run format && pnpm run fix-tailwind-quotes && pnpm run lint",
    "commit": "git add . && git cz",
    "prepare": "lefthook install",
    "db:reset": "pnpm run db:clear && pnpm run db:generate && pnpm run db:migrate",
    "clean": "rm -rf .nuxt dist node_modules pnpm-lock.yaml"
  },
  "dependencies": {
